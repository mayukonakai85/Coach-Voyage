# ============================================
# Coach Voyage 環境変数設定ファイル
# .env.local という名前でコピーして使ってください
# ============================================

# NextAuth.js
# ランダムな文字列を設定してください（例: openssl rand -base64 32 で生成）
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# データベース（SQLite）
DATABASE_URL="file:./dev.db"

# ============================================
# Bunny.net 設定
# Bunny.net ダッシュボード → Stream → ライブラリから確認
# ============================================

# ライブラリID（Stream → ライブラリ → 設定から確認）
BUNNY_LIBRARY_ID=your-library-id

# Stream APIキー（Stream → ライブラリ → APIキーから確認）
BUNNY_API_KEY=your-api-key

# トークン認証キー（Stream → ライブラリ → セキュリティ → トークン認証キー）
# ※ Stream ライブラリのセキュリティ設定でトークン認証を有効にしてください
BUNNY_TOKEN_AUTH_KEY=your-token-auth-key

# 動画CDNホスト名（Stream → ライブラリ → CDNホスト名）
# 例: vz-xxxxxxxx.b-cdn.net
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
