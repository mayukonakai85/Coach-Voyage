// Prisma Schema for Coach Voyage
// フェーズ2（セミナー機能）のモデルはコメントアウトで記載済み

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ユーザーロール
// ADMIN: 管理者（動画・会員の管理が可能）
// MEMBER: 一般会員（動画の閲覧のみ）
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role                 String    @default("MEMBER") // "ADMIN" | "MEMBER"
  title                String?   // 役職・肩書き（例: リーダーコーチ）
  bio                  String?
  avatarUrl            String?
  isActive             Boolean   @default(true)
  loginCount           Int       @default(0)
  learningSince        String?   // 学習開始時期
  contentRequest       String?   // コンテンツリクエスト
  joinedMonth          String?   // 入会月（YYYY-MM形式）
  memberStatus         String    @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "PENDING"
  lastLoginAt          DateTime? // 最終ログイン日時
  showProfilePopup     Boolean   @default(false) // 管理者が次回ログイン時にポップアップ表示を指示
  // Googleフォーム取り込みフィールド（管理者のみ閲覧）
  nameRoman              String?   // お名前（ローマ字）
  address                String?   // 住所
  birthDate              String?   // 生年月日
  phone                  String?   // 携帯電話番号
  companyName            String?   // 会社名/屋号
  companyNameKana        String?   // 会社名/屋号（カナ）
  website                String?   // ホームページ
  referrer               String?   // 紹介者
  coachingSchool         String?   // コーチングスクール/講座
  coachingHours          String?   // コーチング実績（時間）
  coachingCertifications String?   // 保持しているコーチング資格
  formSubmittedAt        DateTime? // フォーム送信日時
  passwordResetToken   String?
  passwordResetExpires DateTime?
  invitedAt            DateTime? // 招待メール送付日時
  paymentEmailSentAt   DateTime? // 決済案内メール送付日時
  tags                 UserTag[]
  seminarLecturers     SeminarLecturer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // フェーズ2: セミナー予約との関連
  // registrations Registration[]
  views         VideoView[]
  notes         Note[]
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  watchLaters   WatchLater[]
  notifications Notification[]
}

// 動画アーカイブ
model Video {
  id           String   @id @default(cuid())
  title        String
  description  String
  thumbnailUrl String?  // カスタムサムネイルURL（nullの場合はBunny.netのデフォルトを使用）
  bunnyVideoId String   // Bunny.net の動画ID（GUID形式）
  category     String   @default("uncategorized") // "入会特典" | "Business doc" | "Coaching doc" | "Short movie" | "uncategorized"
  sortOrder    Int      @default(0) // カテゴリ内の並び順（数字ファイル名の場合）
  recordedAt   DateTime? // 収録日（ファイル名の日付から自動取得）
  publishedAt  DateTime @default(now()) // Bunny.netへのアップロード日
  isPublished        Boolean   @default(true)
  schedulePublishAt  DateTime? // 予約公開日時。設定した日時になったら自動公開
  isSpecialSeminar   Boolean   @default(false) // Special seminarバッジ表示
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  views        VideoView[]
  notes        Note[]
  comments     Comment[]
  likes        Like[]
  favorites    Favorite[]
  watchLaters  WatchLater[]
  lecturers    VideoLecturer[]
}

// 動画の講師
model VideoLecturer {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// 学習ノート（動画ごとの個人メモ）
model Note {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// コメント
model Comment {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  content   String
  parentId  String?  // 返信先コメントID（nullならトップレベル）
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]
}

// お気に入り動画
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// 後で見る
model WatchLater {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

// いいね（コメント or 動画）
model Like {
  id        String   @id @default(cuid())
  userId    String
  videoId   String?
  commentId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@unique([userId, commentId])
}

// 通知
model Notification {
  id        String   @id @default(cuid())
  userId    String   // 通知を受け取るユーザー
  type      String   // "comment" | "reply" | "like"
  message   String
  link      String   // 遷移先URL
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 視聴履歴
model VideoView {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  viewedAt    DateTime @default(now())
  // 将来の分析用（再生位置など）
  lastPosition Int     @default(0) // 秒単位
  user        User     @relation(fields: [userId], references: [id])
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId]) // 1ユーザー1動画につき1レコード
}

// セミナー
model Seminar {
  id          String   @id @default(cuid())
  title       String
  description String?
  scheduledAt DateTime
  zoomUrl     String?
  location    String?  // 会場名・場所（オフラインイベント用）
  isOnline    Boolean  @default(true) // true=オンライン(青), false=オフライン(緑)
  isNext      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lecturers   SeminarLecturer[]
}

// 講師（セミナーに紐づく）
model SeminarLecturer {
  id        String   @id @default(cuid())
  seminarId String
  seminar   Seminar  @relation(fields: [seminarId], references: [id], onDelete: Cascade)
  userId    String?  // メンバー講師の場合
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String   // 表示名
  photoUrl  String?  // 外部講師の写真（base64）
  bio       String?  // 紹介文
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// イベント告知ポップアップ設定（シングルトン）
model EventPopupSettings {
  id         String   @id @default("singleton")
  isEnabled  Boolean  @default(false)
  title      String   @default("")
  body       String   @default("")
  buttonText String   @default("詳細を見る")
  buttonUrl  String?
  updatedAt  DateTime @updatedAt
}

// 興味関心タグ
model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  users     UserTag[]
}

// ユーザーとタグの中間テーブル
model UserTag {
  userId String
  tagId  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}

